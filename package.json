{
  "name": "article-to-slides-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "google:oauth": "tsx src/scripts/authorizeGoogleOAuth.ts",
    "google:oauth:url": "tsx src/scripts/printGoogleOAuthUrl.ts",
    "google:oauth:code": "tsx src/scripts/saveGoogleOAuthCode.ts",
    "codex:preflight": "tsx src/scripts/codexPreflight.ts",
    "jobs:process": "tsx src/scripts/processSlideJob.ts",
    "session:capture": "tsx src/scripts/captureSession.ts",
    "manga:outline": "tsx src/scripts/articleToMangaOutline.ts",
    "manga:check": "tsx src/scripts/checkMangaTemplates.ts",
    "manga:resume": "tsx src/scripts/resumeMangaJob.ts",
    "notebooklm:login": "tsx src/scripts/notebookLmLogin.ts",
    "notebooklm:probe": "tsx src/scripts/notebookLmProbe.ts",
    "slides:create": "tsx src/scripts/createSlidesFromOutline.ts",
    "slides:create:gas": "tsx src/scripts/createSlidesViaGas.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "firebase:verify": "node scripts/verify-firebase-admin.mjs"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@local/content-extractor": "file:../content-extractor",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.9.3",
    "fastify": "^5.3.2",
    "firebase-admin": "^14.0.0",
    "googleapis": "^148.0.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.32",
    "eslint": "^10.7.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0"
  }
}
