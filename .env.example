PORT=3000

# Slack Socket Mode
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=...
SLACK_COMPLETION_CHANNEL_ID=C000000000

# Google OAuth. This mode saves files to the authenticated user's Drive.
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CREDENTIALS=./google-oauth-credentials.json
GOOGLE_OAUTH_TOKEN=./google-oauth-token.json
GOOGLE_DRIVE_FOLDER_ID=...
GOOGLE_SLIDES_TEMPLATE_ID=...
GAS_WEB_APP_URL=https://script.google.com/macros/s/.../exec

# リサーチモード（Web 検索でスライド生成する場合に使用）
TAVILY_API_KEY=tvly-your-tavily-api-key

# YouTube Data API。未設定でも字幕は取得できるが、設定すると動画メタデータも取得する。
# 共有抽出器の資格情報。bookmark-curator と共通のため、中立な
# %USERPROFILE%\.content-extractor\.env に置けば両アプリで共有される。
# ローカルで上書きする場合のみコメントを外して指定する(空のまま残さない)。
# YOUTUBE_API_KEY=your_youtube_api_key_here

# X(Twitter)投稿の本文取得。ログイン済み Playwright storageState の JSON パスを指定すると
# 有効化される。未設定の場合、X 投稿はテキスト取得できずフォールバックする。
#
# これは「あなたのログイン済み X セッション」= アプリ非依存のユーザー資格情報です。
# 特定リポジトリ配下ではなく、どのプロジェクトにも属さない中立な場所に置いてください。
# 未設定なら既定で %USERPROFILE%\.content-extractor\x-session.json を参照します。
# 別の場所に置く場合のみ、コメントを外して指定してください(空のまま残さない)。
# X_SESSION_STATE_PATH=C:\Users\<you>\.content-extractor\x-session.json
# X_HEADLESS=true

# Claude Code — headless long-lived auth token.
# On Windows, the normal OAuth token expires after ~8 hours and does not auto-refresh in headless mode,
# causing `claude -p` and `claude --chrome` calls to fail with 401 errors.
# Fix: run `claude setup-token` interactively once (browser auth required), copy the displayed token here.
# IMPORTANT: use ANTHROPIC_AUTH_TOKEN — CLAUDE_CODE_OAUTH_TOKEN does NOT take priority over an active
# subscription login and silently does nothing.
ANTHROPIC_AUTH_TOKEN=

# Claude Code settings (NotebookLM autosync / manga generation via `claude` CLI).
CLAUDE_CLI_COMMAND=claude
CLAUDE_MODEL=opus
CLAUDE_EXEC_TIMEOUT_MS=900000

# Local Codex automation. This does not call metered LLM APIs from Node.js.
AUTO_RUN_CODEX=true
# Windowsでは絶対パスを必ず設定してください。WindowsApps配下のパスは使用不可。
# CODEX_CLI_COMMAND=C:\Users\<YourName>\AppData\Local\OpenAI\Codex\bin\codex.exe
CODEX_CLI_COMMAND=codex
CODEX_RUNNER_HOME=./.codex-runner-home
# Optional. Defaults to %USERPROFILE%\.codex on Windows.
CODEX_SOURCE_HOME=
CODEX_EXEC_SANDBOX=workspace-write
CODEX_EXEC_FULL_AUTO=true
CODEX_EXEC_TIMEOUT_MS=900000

# Optional service account mode.
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# Summary provider. Default avoids metered LLM APIs.
SUMMARY_PROVIDER=codex_job
