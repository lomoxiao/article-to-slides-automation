PORT=3000

# Slack Socket Mode
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=...
SLACK_COMPLETION_CHANNEL_ID=C000000000

# Google OAuth. This mode saves files to the authenticated user's Drive.
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CREDENTIALS=./google-oauth-credentials.json
GOOGLE_OAUTH_TOKEN=./google-oauth-token.json
GOOGLE_DRIVE_FOLDER_ID=...
GOOGLE_SLIDES_TEMPLATE_ID=...
GAS_WEB_APP_URL=https://script.google.com/macros/s/.../exec

# リサーチモード（Web 検索でスライド生成する場合に使用）
TAVILY_API_KEY=tvly-your-tavily-api-key

# Local Codex automation. This does not call metered LLM APIs from Node.js.
AUTO_RUN_CODEX=true
# Windowsでは絶対パスを必ず設定してください。WindowsApps配下のパスは使用不可。
# CODEX_CLI_COMMAND=C:\Users\<YourName>\AppData\Local\OpenAI\Codex\bin\codex.exe
CODEX_CLI_COMMAND=codex
CODEX_RUNNER_HOME=./.codex-runner-home
# Optional. Defaults to %USERPROFILE%\.codex on Windows.
CODEX_SOURCE_HOME=
CODEX_EXEC_SANDBOX=workspace-write
CODEX_EXEC_FULL_AUTO=true
CODEX_EXEC_TIMEOUT_MS=900000

# Optional service account mode.
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# Summary provider. Default avoids metered LLM APIs.
SUMMARY_PROVIDER=codex_job
